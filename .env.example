# Azure App Service Configuration

# Environment: Development, Staging, or Production
ASPNETCORE_ENVIRONMENT=Development

# Table Storage Configuration
TABLE_STORAGE_URI=https://yourstorageaccount.table.core.windows.net
TABLE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=youraccountkey;EndpointSuffix=core.windows.net

# Application Settings
APP_NAME=AppService
APP_VERSION=1.0.0
LOG_LEVEL=Information

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-appservice-dev
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_APP_SERVICE_NAME=appservice-dev

# Optional: Application Insights
APPLICATION_INSIGHTS_CONNECTION_STRING=your-connection-string
