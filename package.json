{
  "name": "appservice",
  "version": "1.0.0",
  "description": "Azure App Service REST API with Table Storage",
  "scripts": {
    "azurite": "azurite --tableHost 127.0.0.1 --loose --location ./data",
    "dotnet": "cross-env ASPNETCORE_ENVIRONMENT=Development dotnet run",
    "start": "concurrently \"npm run azurite\" \"npm run dotnet\" --names \"azurite,dotnet\" --prefix \"[{name}]\" --kill-others-on-exit",
    "dev": "npm run start"
  },
  "keywords": [
    "azure",
    "app-service",
    "rest-api",
    "table-storage",
    "dotnet"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "concurrently": "^8.2.2"
  }
}
